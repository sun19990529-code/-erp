# PostgreSQL 数据库连接配置
DB_HOST=localhost
DB_PORT=54321
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=msgy-erp

# JWT 密钥（生产环境必须设置）
# JWT_SECRET=your_jwt_secret_here
# JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# 服务端口
# PORT=3198

# 环境标识
# NODE_ENV=production

# 群机器人 Webhook（留空则不推送，可同时配置多个平台）
# 企业微信群机器人
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=你的key
# 钉钉群机器人
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=你的token
# 钉钉加签密钥（可选，建议生产环境开启）
# DINGTALK_SECRET=SECxxxxx

# 钉钉 Outgoing 机器人签名验证（群内 @机器人 查询用）
# 回调地址：http://你的公网IP:3198/api/bot/dingtalk
# DINGTALK_OUTGOING_TOKEN=你的outgoing签名token
